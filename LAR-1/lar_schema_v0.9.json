{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/carlsonchik/LAR-1/schema/lar_v0.9.schema.json",
  "title": "LAR-1 Utterance",
  "description": "Schema for LAR-1 JSON utterance format v0.9.0",
  "type": "object",
  "required": ["act", "time", "space", "mind", "content"],
  "properties": {
    "act": {
      "type": "string",
      "enum": ["OBS", "INF", "ASK", "PRP", "CMD", "ACK", "NTF", "WRN", "ERR", "COM", "REV", "MAP", "SYC", "END"],
      "description": "Речевой акт"
    },
    "time": {
      "type": "string",
      "enum": ["NOW", "CTX", "MEM", "PRE", "ROL", "CKP", "EVT", "NIL"],
      "description": "Временной фрейм"
    },
    "space": {
      "type": "string",
      "enum": ["LOC", "LAT", "RET", "TOL", "GRF", "PEER", "ENV", "NIL"],
      "description": "Пространственный фрейм"
    },
    "mind": {
      "type": "string",
      "enum": ["ATN", "HYP", "CST", "INF", "DEC", "AMB", "SPL", "REF"],
      "description": "Когнитивный фрейм"
    },
    "evidence": {
      "oneOf": [
        {
          "type": "string",
          "enum": ["PRETRAIN", "CONTEXT", "MEMORY", "TOOL", "USER", "PEERMSG", "SYNTH", "SPEC"]
        },
        {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["PRETRAIN", "CONTEXT", "MEMORY", "TOOL", "USER", "PEERMSG", "SYNTH", "SPEC"]
          },
          "minItems": 1
        }
      ],
      "description": "Доказательность (опционально)"
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1,
      "description": "Уверенность 0.0–1.0 (опционально)"
    },
    "route": {
      "type": "object",
      "description": "Маршрутизация (опционально)",
      "properties": {
        "to": { "type": "string" },
        "thread": { "type": "string" },
        "from": { "type": "string" }
      },
      "additionalProperties": true
    },
    "content": {
      "type": "string",
      "minLength": 1,
      "description": "Полезная нагрузка"
    },
    "meta": {
      "type": "object",
      "description": "Метаданные (опционально)",
      "properties": {
        "agent_id": { "type": "string" },
        "turn_id": { "type": "string" },
        "lang": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}